{
  "name": "workspace",
  "private": true,
  "version": "0.1.0",
  "description": "Example todo application",
  "license": "UNLICENSED",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:schema": "npm --workspace packages/schema run build:asset",
    "sdk-gen": "npm --workspace packages/schema run sdk-gen",
    "build:sdk": "npm --workspace packages/sdk run build",
    "dev": "npm --workspace packages/app run dev",
    "typecheck": "npm --workspace packages/sdk run typecheck && npm --workspace packages/app run typecheck"
  }
}
