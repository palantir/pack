{
  "name": "<%= projectName %>",
  "private": true,
  "version": "0.1.0",
  "description": "<%= answers.description %>",
  "license": "UNLICENSED",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
<% if (answers.firstParty) { -%>
    "build:asset": "npm --workspace packages/schema run build:asset",
<% } else { -%>
    "deploy": "npm --workspace packages/schema run deploy",
<% } -%>
    "build:sdk": "npm --workspace packages/sdk run build",
    "dev": "npm --workspace packages/app run dev",
    "sdk-gen": "npm --workspace packages/schema run sdk-gen",
    "typecheck": "npm --workspace packages/sdk run typecheck && npm --workspace packages/app run typecheck"
  }
}
