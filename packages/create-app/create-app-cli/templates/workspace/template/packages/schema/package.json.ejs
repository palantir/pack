{
  "name": "<%= answers.scope %>.schema",
  "private": true,
  "version": "0.1.0",
  "description": "<%= answers.description %> schema",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build:ir": "type-gen schema ir -i src/schema.mjs -o build/ir.json --config pack-config.json",
<% if (answers.firstParty) { -%>
    "build:asset": "npm run build:ir && type-gen ir asset -i build/ir.json -o build/asset.json",
    "deploy": "npm run build:ir && type-gen ir deploy --ir build/ir.json --base-url $FOUNDRY_URL --auth $FOUNDRY_TOKEN --first-party --ontology-rid $ONTOLOGY_RID --file-system-type ${FILE_SYSTEM_TYPE:-ARTIFACTS}",
<% } else { -%>
    "deploy": "npm run build:ir && type-gen ir deploy --ir build/ir.json --base-url $FOUNDRY_URL --auth $FOUNDRY_TOKEN --parent-folder $PARENT_FOLDER_RID --file-system-type ${FILE_SYSTEM_TYPE:-ARTIFACTS}",
<% } -%>
    "clean": "rimraf build dist *.tgz tsconfig.tsbuildinfo",
    "sdk-gen": "bash scripts/build-sdk.sh",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@palantir/pack.document-schema.type-gen": "^0.18.0",
    "@palantir/pack.schema": "^0.10.0",
    "@palantir/pack.sdkgen": "^0.5.0",
    "@palantir/pack.sdkgen.pack-versioned-template": "^0.9.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.9.0"
  }
}
