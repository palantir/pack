# Copy this file to `.env.local` and fill in your Foundry configuration.

# Foundry configuration
VITE_FOUNDRY_CLIENT_ID=your-client-id
VITE_FOUNDRY_API_URL=https://example.palantirfoundry.com
VITE_FOUNDRY_ONTOLOGY_RID=ri.ontology.main.ontology.00000000-0000-0000-0000-000000000000
VITE_FOUNDRY_REDIRECT_URL=https://localhost:5173/auth/callback

# The document type name configured in packages/schema/pack-config.json
VITE_PACK_DOCUMENT_TYPE_NAME=your-document-type-name

# Dev server (optional)
DEV_SERVER_PORT=5173
